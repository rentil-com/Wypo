{
  "info": {
    "_postman_id": "33d709d7-5a4b-4d83-9f8a-77714fd8a286",
    "name": "Worker API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get worker settings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{worker_api_key}}",
            "type": "text"
          }
        ],
        "url": "{{worker_base_url}}/settings"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains all worker settings\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.settings).to.be.an(\"object\");",
              "  pm.expect(body.settings).to.have.all.keys(",
              "    \"cron_daily_promotion\",",
              "    \"timezone\",",
              "    \"discount_min_percent\",",
              "    \"discount_max_percent\"",
              "  );",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Run promotion without API key",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{worker_base_url}}/runpromotion"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 401\", function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test(\"Response rejects missing API key\", function () {",
              "  pm.expect(pm.response.json().error)",
              "    .to.eql(\"Brak lub nieprawidlowy klucz API.\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Run promotion",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{worker_api_key}}",
            "type": "text"
          }
        ],
        "url": "{{worker_base_url}}/runpromotion"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains a valid promotion outcome\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect([\"success\", \"skipped\"]).to.include(body.status);",
              "",
              "  if (body.status === \"success\") {",
              "    pm.expect(body.promotion).to.be.an(\"object\");",
              "    pm.expect(body.promotion.item_id).to.be.a(\"number\");",
              "    pm.expect(body.promotion.discount_percent).to.be.a(\"number\");",
              "    pm.expect(body.promotion.promotional_price).to.be.a(\"number\");",
              "  } else {",
              "    pm.expect(body.promotion).to.eql(null);",
              "  }",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
