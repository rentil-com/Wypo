DATABASE_CONNECTION_URL=postgresql://wypozyczalnia:password@10.0.0.10:5432/database
NODE_ENV=dev/prod
S3_ENDPOINT_API=https://s3.webpage.com
S3_WEB_ENDPOINT=https://s3.webpage2.com/
S3_API_KEY=api_key
S3_API_SECRET=secret
S3_BUCKET=wypozyczalnia
S3_REGION=us-east
S3_FORCE_PATH_STYLE=true
S3_ITEMS_IMAGES=items/images/
S3_CATEGORIES_IMAGES=categories/images/
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=password
SMTP_TIMEOUT_MS=15000
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=Wypozyczalnia Narzedzi
MAIL_BRAND_NAME=Wypozyczalnia Narzedzi
MAIL_APP_URL=https://example.com
MAIL_LOGO_1X1_URL=https://example.com/logo-1x1.png
MAIL_LOGO_4X1_URL=https://example.com/logo-4x1.png
MAIL_PICKUP_LOCATION=Punkt wypozyczalni, ul. Przykladowa 1
MAIL_PICKUP_HOURS=9:00-17:00
MAIL_RETURN_LOCATION=Punkt wypozyczalni, ul. Przykladowa 1
MAIL_CONTACT=kontakt@example.com
